[Unit]
Description=ContextKeep V2.1 WebUI
After=network.target

[Service]
Type=simple
User={{USER}}
WorkingDirectory={{WORKDIR}}
Environment=CONTEXTKEEP_DB_PATH={{WORKDIR}}/data/contextkeep.db
ExecStart={{PYTHON}} webui.py --host 0.0.0.0 --port 5000
Restart=always
RestartSec=10
StandardOutput=append:{{WORKDIR}}/logs/contextkeep_webui.log
StandardError=append:{{WORKDIR}}/logs/contextkeep_webui_error.log

[Install]
WantedBy=multi-user.target
