[Unit]
Description=ContextKeep V2.1 MCP Server (HTTP)
After=network.target

[Service]
Type=simple
User={{USER}}
WorkingDirectory={{WORKDIR}}
Environment=CONTEXTKEEP_DB_PATH={{WORKDIR}}/data/contextkeep.db
ExecStart={{PYTHON}} server.py --transport http --host 0.0.0.0 --port 5100
Restart=always
RestartSec=10
StandardOutput=append:{{WORKDIR}}/logs/contextkeep_server.log
StandardError=append:{{WORKDIR}}/logs/contextkeep_server_error.log

[Install]
WantedBy=multi-user.target
